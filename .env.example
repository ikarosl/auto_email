NODE_ENV=development
API_HOST=0.0.0.0
API_PORT=3000
DATABASE_URL=postgresql://postgres:123456@localhost:5432/email_inquiry?schema=public
STORAGE_DRIVER=prisma

IMAP_HOST=
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=
IMAP_PASS=
IMAP_MAILBOX=INBOX
IMAP_FETCH_LIMIT=5
IMAP_FETCH_UID=
IMAP_BODY_PREVIEW_LIMIT=8000
IMAP_FETCH_LIMIT=5
IMAP_FETCH_UID=
IMAP_BODY_PREVIEW_LIMIT=8000
IMAP_POLL_INTERVAL_MS=30000
# process_existing: 首次启动拉取全网箱邮件同步入库
# mark_existing_seen: 跳过已有邮件，仅处理后续新邮件
IMAP_POLL_BOOTSTRAP_MODE=process_existing

DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_REASONING_EFFORT=high
DEEPSEEK_THINKING_ENABLED=true
AI_EMAIL_ANALYSIS_ENABLED=true
AI_EMAIL_ANALYSIS_MODEL=deepseek-v4-pro
