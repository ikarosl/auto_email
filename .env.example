NODE_ENV=development
API_HOST=0.0.0.0
API_PORT=3000
DATABASE_URL=postgresql://postgres:123456@localhost:5432/email_inquiry?schema=public
STORAGE_DRIVER=prisma

IMAP_HOST=
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=
IMAP_PASS=
IMAP_MAILBOX=INBOX
IMAP_FETCH_LIMIT=5
IMAP_FETCH_UID=
IMAP_BODY_PREVIEW_LIMIT=8000
IMAP_POLL_ENABLED=true
IMAP_POLL_INTERVAL_MS=30000
# process_existing: import existing mailbox messages into the database.
# mark_existing_seen: skip existing messages and only process new ones.
IMAP_POLL_BOOTSTRAP_MODE=mark_existing_seen

DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_REASONING_EFFORT=high
DEEPSEEK_THINKING_ENABLED=true
AI_EMAIL_ANALYSIS_ENABLED=true
AI_EMAIL_ANALYSIS_MODEL=deepseek-v4-pro
AI_STATUS_TRANSITION_ENABLED=false
# true evaluates and audits transitions without changing inquiry_cases.status.
AI_STATUS_TRANSITION_DRY_RUN=true
AI_STATUS_TRANSITION_MIN_CONFIDENCE=0.90
AI_CONTEXT_MAX_TOKENS=64000
AI_CONTEXT_INPUT_TOKEN_RATIO=0.8
AI_CONTEXT_OUTPUT_TOKEN_RATIO=0.1
AI_CONTEXT_SAFETY_TOKEN_RATIO=0.1
AI_CONTEXT_SUMMARY_MODEL=deepseek-v4-pro
# Optional. Leave empty to use the built-in summary system prompt.
AI_CONTEXT_SUMMARY_SYSTEM_PROMPT=
AI_DEBUG_LOG_ENABLED=true
AI_DEBUG_LOG_PATH=logs/ai-interactions-dev.jsonl
EMAIL_SANITIZER_DEBUG_LOG_ENABLED=true
EMAIL_SANITIZER_DEBUG_LOG_PATH=logs/email-sanitizer-debug.jsonl

AI_MAILBOX=silent@hzbeat.com

ATTACHMENT_STORAGE_DIR=storage/attachments
ATTACHMENT_MAX_FILE_SIZE_MB=20
ATTACHMENT_PARSE_TIMEOUT_MS=15000
ATTACHMENT_CONTEXT_MAX_CHARS=8000
ATTACHMENT_PREVIEW_MAX_CHARS=1000
ATTACHMENT_AI_READER_ENABLED=false
ATTACHMENT_AI_READER_PROVIDER=openai
ATTACHMENT_AI_READER_API_KEY=
ATTACHMENT_AI_READER_BASE_URL=
ATTACHMENT_AI_READER_MODEL=gpt-4o
ATTACHMENT_AI_READER_PROMPT=
