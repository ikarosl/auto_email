{
  "name": "@email-inquiry/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:pull": "prisma db pull",
    "db:studio": "prisma studio",
    "db:migrate": "node database/run-migrations.mjs",
    "db:check": "node database/check-tables.mjs",
    "demo:deepseek": "tsx src/config/deepseek-chat-demo.ts",
    "demo:imap": "tsx src/modules/email/infrastructure/adapters/imap-pull-demo.ts",
    "demo:imap-to-inquiry": "tsx src/modules/email/infrastructure/adapters/imap-to-inquiry-demo.ts",
    "demo:poll-inbox": "tsx src/modules/email/infrastructure/adapters/imap-poll-inbox-service.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test \"src/**/*.spec.ts\"",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@email-inquiry/shared": "workspace:*",
    "@nestjs/common": "^11.1.3",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.3",
    "@nestjs/platform-express": "^11.1.3",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "cheerio": "1.1.2",
    "dotenv": "^16.4.7",
    "entities": "7.0.1",
    "html-to-text": "10.0.0",
    "imapflow": "^1.0.194",
    "mailparser": "^3.7.2",
    "openai": "^5.8.2",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "tiktoken": "^1.0.22",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/html-to-text": "^9.0.4",
    "@types/mailparser": "^3.4.6",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
