generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum InquiryBusinessStage {
  intake
  technical_review
  commercial
  contract
}

enum InquiryActionOwner {
  us
  customer
  none
}

enum InquiryLifecycleStatus {
  active
  won
  lost
  invalid
}

model MailboxAccount {
  id              String             @id @default(dbgenerated("'mailbox_' || gen_random_uuid()::TEXT"))
  emailAddress    String             @unique @map("email_address")
  provider        String?
  imapHost        String?            @map("imap_host")
  imapPort        Int                @default(993) @map("imap_port")
  imapSecure      Boolean            @default(true) @map("imap_secure")
  status          String             @default("active")
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime           @default(now()) @map("updated_at") @db.Timestamptz(6)
  syncStates      MailboxSyncState[]
  emailThreads    EmailThread[]
  emailMessages   EmailMessage[]
  processedEmails ProcessedEmail[]

  @@map("mailbox_accounts")
}

model MailboxSyncState {
  id                   String         @id @default(dbgenerated("'mailbox_sync_' || gen_random_uuid()::TEXT"))
  mailboxAccountId     String         @map("mailbox_account_id")
  mailboxName          String         @default("INBOX") @map("mailbox_name")
  uidValidity          BigInt?        @map("uid_validity")
  lastSeenUid          BigInt?        @map("last_seen_uid")
  lastProcessedUid     BigInt?        @map("last_processed_uid")
  bootstrapCompletedAt DateTime?      @map("bootstrap_completed_at") @db.Timestamptz(6)
  createdAt            DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime       @default(now()) @map("updated_at") @db.Timestamptz(6)
  mailboxAccount       MailboxAccount @relation(fields: [mailboxAccountId], references: [id], onDelete: Cascade)

  @@unique([mailboxAccountId, mailboxName])
  @@map("mailbox_sync_states")
}

model Customer {
  id                  String        @id @default(dbgenerated("'customer_' || gen_random_uuid()::TEXT"))
  organizationId      String?       @map("organization_id")
  email               String        @unique
  name                String?
  domain              String?
  companyName         String?       @map("company_name")
  country             String?
  source              String        @default("email")
  status              String        @default("unknown")
  invalidReason       String?       @map("invalid_reason")
  statusUpdatedAt     DateTime?     @map("status_updated_at") @db.Timestamptz(6)
  remark              String?
  createdAt           DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime      @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt           DateTime?     @map("deleted_at") @db.Timestamptz(6)
  organization        Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  inquiryCases        InquiryCase[] @relation("InquiryCustomer")
  primaryInquiryCases InquiryCase[] @relation("InquiryPrimaryCustomer")

  @@index([status])
  @@index([domain])
  @@index([organizationId])
  @@map("customers")
}

model Organization {
  id           String        @id @default(dbgenerated("'org_' || gen_random_uuid()::TEXT"))
  name         String
  domain       String?       @unique
  status       String        @default("active")
  source       String        @default("email_domain")
  remark       String?
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime      @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?     @map("deleted_at") @db.Timestamptz(6)
  customers    Customer[]
  inquiryCases InquiryCase[]

  @@index([domain])
  @@index([status])
  @@map("organizations")
}

model EmailThread {
  id                String         @id @default(dbgenerated("'thread_' || gen_random_uuid()::TEXT"))
  mailboxAccountId  String         @map("mailbox_account_id")
  threadKey         String         @map("thread_key")
  externalThreadId  String?        @map("external_thread_id")
  subjectNormalized String?        @map("subject_normalized")
  customerEmail     String?        @map("customer_email")
  latestMessageAt   DateTime?      @map("latest_message_at") @db.Timestamptz(6)
  createdAt         DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime       @default(now()) @map("updated_at") @db.Timestamptz(6)
  mailboxAccount    MailboxAccount @relation(fields: [mailboxAccountId], references: [id], onDelete: Cascade)
  emailMessages     EmailMessage[]

  @@unique([mailboxAccountId, threadKey])
  @@map("email_threads")
}

model EmailMessage {
  id                   String              @id @default(dbgenerated("'email_' || gen_random_uuid()::TEXT"))
  mailboxAccountId     String?             @map("mailbox_account_id")
  emailThreadId        String?             @map("email_thread_id")
  direction            String
  mailboxName          String              @default("INBOX") @map("mailbox_name")
  uidValidity          BigInt?             @map("uid_validity")
  uid                  BigInt?
  messageId            String?             @map("message_id")
  inReplyTo            String?             @map("in_reply_to")
  referencesJson       Json                @default("[]") @map("references_json")
  fromEmail            String              @map("from_email")
  fromName             String?             @map("from_name")
  toEmails             Json                @default("[]") @map("to_emails")
  ccEmails             Json                @default("[]") @map("cc_emails")
  subject              String?
  bodyText             String?             @map("body_text")
  bodyHtml             String?             @map("body_html")
  hasAttachments       Boolean             @default(false) @map("has_attachments")
  attachmentCount      Int                 @default(0) @map("attachment_count")
  rawSource            String?             @map("raw_source")
  receivedAt           DateTime            @map("received_at") @db.Timestamptz(6)
  source               String              @default("imap")
  createdAt            DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime            @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt            DateTime?           @map("deleted_at") @db.Timestamptz(6)
  mailboxAccount       MailboxAccount?     @relation(fields: [mailboxAccountId], references: [id], onDelete: SetNull)
  emailThread          EmailThread?        @relation(fields: [emailThreadId], references: [id], onDelete: SetNull)
  inquiryMessages      InquiryMessage[]
  analysisDecisions    EmailAnalysisDecision[]
  businessEvents       InquiryBusinessEvent[]
  stateDecisions       InquiryStateDecision[]
  triggeredRecoveries  EmailRecoveryRecord[] @relation("RecoveryTriggerEmail")
  recoveredByRecords   EmailRecoveryRecord[] @relation("RecoveredEmail")
  sourceReplyDrafts    ReplyDraft[]        @relation("ReplyDraftSourceEmail")
  sentReplyDrafts      ReplyDraft[]        @relation("ReplyDraftSentEmail")
  contextSnapshots     AiContextSnapshot[]
  updatedStructuredFacts InquiryStructuredFact[]
  attachments          EmailAttachment[]
  sendAttempts         EmailSendAttempt[]

  @@index([emailThreadId])
  @@index([fromEmail])
  @@index([receivedAt])
  @@index([direction])
  @@map("email_messages")
}

model EmailAttachment {
  id                 String        @id @default(dbgenerated("'attachment_' || gen_random_uuid()::TEXT"))
  emailMessageId     String        @map("email_message_id")
  inquiryCaseId      String?       @map("inquiry_case_id")
  originalFileName   String?       @map("original_file_name")
  safeFileName       String        @map("safe_file_name")
  contentId          String?       @map("content_id")
  contentDisposition String?       @map("content_disposition")
  mimeType           String        @map("mime_type")
  fileExtension      String?       @map("file_extension")
  fileSize           BigInt        @map("file_size")
  contentHash        String?       @map("content_hash")
  storageProvider    String        @default("local") @map("storage_provider")
  storagePath        String?       @map("storage_path")
  parseStatus        String        @default("pending") @map("parse_status")
  parseStrategy      String?       @map("parse_strategy")
  parsedText         String?       @map("parsed_text")
  parsedTextPreview  String?       @map("parsed_text_preview")
  parsedTextLength   Int           @default(0) @map("parsed_text_length")
  parseErrorCode     String?       @map("parse_error_code")
  parseErrorMessage  String?       @map("parse_error_message")
  parsedAt           DateTime?     @map("parsed_at") @db.Timestamptz(6)
  ocrStatus          String        @default("skipped") @map("ocr_status")
  ocrProvider        String?       @map("ocr_provider")
  ocrText            String?       @map("ocr_text")
  ocrTextPreview     String?       @map("ocr_text_preview")
  ocrResultJson      Json          @default("{}") @map("ocr_result_json")
  ocrErrorCode       String?       @map("ocr_error_code")
  ocrAt              DateTime?     @map("ocr_at") @db.Timestamptz(6)
  isInline           Boolean       @default(false) @map("is_inline")
  isContextCandidate Boolean       @default(true) @map("is_context_candidate")
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime      @default(now()) @map("updated_at") @db.Timestamptz(6)
  emailMessage       EmailMessage  @relation(fields: [emailMessageId], references: [id], onDelete: Cascade)
  inquiryCase        InquiryCase?  @relation(fields: [inquiryCaseId], references: [id], onDelete: SetNull)
  replyDraftLinks    ReplyDraftAttachment[]

  @@index([emailMessageId])
  @@index([inquiryCaseId])
  @@index([parseStatus])
  @@index([contentHash])
  @@map("email_attachments")
}

model InquiryCase {
  id              String                  @id @default(dbgenerated("'inquiry_' || gen_random_uuid()::TEXT"))
  customerId      String                  @map("customer_id")
  organizationId  String?                 @map("organization_id")
  primaryCustomerId String?               @map("primary_customer_id")
  businessStage   InquiryBusinessStage    @default(intake) @map("business_stage")
  actionOwner     InquiryActionOwner      @default(us) @map("action_owner")
  lifecycleStatus InquiryLifecycleStatus  @default(active) @map("lifecycle_status")
  stateVersion    Int                     @default(0) @map("state_version")
  subject         String?
  rawSubject      String?                 @map("raw_subject")
  businessSubject String?                 @map("business_subject")
  businessSubjectSource String            @default("raw_email") @map("business_subject_source")
  businessSubjectLocked Boolean           @default(false) @map("business_subject_locked")
  businessSubjectUpdatedAt DateTime?      @map("business_subject_updated_at") @db.Timestamptz(6)
  productType     String?                 @map("product_type")
  latestMessageAt DateTime?               @map("latest_message_at") @db.Timestamptz(6)
  closedAt        DateTime?               @map("closed_at") @db.Timestamptz(6)
  createdAt       DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime                @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?               @map("deleted_at") @db.Timestamptz(6)
  customer        Customer                @relation("InquiryCustomer", fields: [customerId], references: [id], onDelete: Restrict)
  organization    Organization?           @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  primaryCustomer Customer?               @relation("InquiryPrimaryCustomer", fields: [primaryCustomerId], references: [id], onDelete: SetNull)
  inquiryMessages InquiryMessage[]
  analysisDecisions EmailAnalysisDecision[]
  businessEvents  InquiryBusinessEvent[]
  stateDecisions  InquiryStateDecision[]
  stateTransitions InquiryStateTransition[]
  recoveryRecords EmailRecoveryRecord[]
  structuredFacts InquiryStructuredFact?
  replyDrafts     ReplyDraft[]
  contextSnapshots AiContextSnapshot[]
  contextSummary  InquiryContextSummary?
  attachments     EmailAttachment[]
  sendAttempts    EmailSendAttempt[]

  @@index([customerId])
  @@index([organizationId])
  @@index([primaryCustomerId])
  @@index([businessStage])
  @@index([actionOwner])
  @@index([lifecycleStatus])
  @@index([latestMessageAt])
  @@map("inquiry_cases")
}

model InquiryMessage {
  id             String       @id @default(dbgenerated("'inquiry_message_' || gen_random_uuid()::TEXT"))
  inquiryCaseId String       @map("inquiry_case_id")
  emailMessageId String      @map("email_message_id")
  relationType   String      @default("reply") @map("relation_type")
  direction      String
  createdByType  String      @default("system") @map("created_by_type")
  createdBy      String?     @map("created_by")
  relationReason String?     @map("relation_reason")
  createdAt      DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime    @default(now()) @map("updated_at") @db.Timestamptz(6)
  inquiryCase    InquiryCase @relation(fields: [inquiryCaseId], references: [id], onDelete: Cascade)
  emailMessage   EmailMessage @relation(fields: [emailMessageId], references: [id], onDelete: Cascade)

  @@unique([inquiryCaseId, emailMessageId])
  @@index([inquiryCaseId])
  @@index([emailMessageId])
  @@map("inquiry_messages")
}

model ProcessedEmail {
  id               String         @id @default(dbgenerated("'processed_email_' || gen_random_uuid()::TEXT"))
  mailboxAccountId String         @map("mailbox_account_id")
  mailboxName      String         @default("INBOX") @map("mailbox_name")
  uidValidity      BigInt         @map("uid_validity")
  uid              BigInt
  messageId        String?        @map("message_id")
  seenAt           DateTime       @default(now()) @map("seen_at") @db.Timestamptz(6)
  processedAt      DateTime?      @map("processed_at") @db.Timestamptz(6)
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  mailboxAccount   MailboxAccount @relation(fields: [mailboxAccountId], references: [id], onDelete: Cascade)

  @@unique([mailboxAccountId, mailboxName, uidValidity, uid])
  @@index([messageId])
  @@map("processed_emails")
}

model EmailAnalysisDecision {
  id                       String        @id @default(dbgenerated("'email_analysis_' || gen_random_uuid()::TEXT"))
  emailMessageId           String        @map("email_message_id")
  inquiryCaseId            String        @map("inquiry_case_id")
  contextSnapshotId        String?       @map("context_snapshot_id")
  direction                String
  messageClassification    String?       @map("message_classification")
  suggestedBusinessStage   InquiryBusinessStage?   @map("suggested_business_stage")
  suggestedActionOwner     InquiryActionOwner?     @map("suggested_action_owner")
  suggestedLifecycleStatus InquiryLifecycleStatus? @map("suggested_lifecycle_status")
  confidence               Decimal?      @db.Decimal(5, 4)
  riskLevel                String?       @map("risk_level")
  reason                   String?
  missingFields            Json          @default("[]") @map("missing_fields")
  extractedRequirements    Json          @default("{}") @map("extracted_requirements")
  quoteBoundaryDetected    Boolean       @default(false) @map("quote_boundary_detected")
  humanReviewRequired      Boolean       @default(false) @map("human_review_required")
  nextAction               String?       @map("next_action")
  rawResult                Json          @default("{}") @map("raw_result")
  rawOutput                String?       @map("raw_output")
  modelName                String?       @map("model_name")
  promptVersion            String?       @map("prompt_version")
  success                  Boolean       @default(true)
  errorCode                String?       @map("error_code")
  errorMessage             String?       @map("error_message")
  idempotencyKey           String        @unique @map("idempotency_key")
  createdAt                DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  emailMessage             EmailMessage  @relation(fields: [emailMessageId], references: [id], onDelete: Cascade)
  inquiryCase              InquiryCase   @relation(fields: [inquiryCaseId], references: [id], onDelete: Cascade)
  replyDrafts              ReplyDraft[]
  businessEvents           InquiryBusinessEvent[]
  stateDecision            InquiryStateDecision?

  @@index([emailMessageId])
  @@index([inquiryCaseId, createdAt])
  @@index([messageClassification])
  @@map("email_analysis_decisions")
}

model InquiryBusinessEvent {
  id                 String        @id @default(dbgenerated("'business_event_' || gen_random_uuid()::TEXT"))
  inquiryCaseId      String        @map("inquiry_case_id")
  emailMessageId     String?       @map("email_message_id")
  analysisDecisionId String?       @map("analysis_decision_id")
  correctedEventId   String?       @map("corrected_event_id")
  eventType          String        @map("event_type")
  actor              String
  sequenceInEmail    Int           @default(0) @map("sequence_in_email")
  confidence         Decimal?      @db.Decimal(5, 4)
  evidence           String?
  payloadJson        Json          @default("{}") @map("payload_json")
  sourceType         String        @default("ai") @map("source_type")
  occurredAt         DateTime      @map("occurred_at") @db.Timestamptz(6)
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  inquiryCase        InquiryCase   @relation(fields: [inquiryCaseId], references: [id], onDelete: Cascade)
  emailMessage       EmailMessage? @relation(fields: [emailMessageId], references: [id], onDelete: SetNull)
  analysisDecision   EmailAnalysisDecision? @relation(fields: [analysisDecisionId], references: [id], onDelete: SetNull)
  correctedEvent     InquiryBusinessEvent? @relation("BusinessEventCorrections", fields: [correctedEventId], references: [id], onDelete: SetNull)
  corrections        InquiryBusinessEvent[] @relation("BusinessEventCorrections")

  @@index([inquiryCaseId, occurredAt])
  @@index([emailMessageId])
  @@index([analysisDecisionId])
  @@index([eventType])
  @@map("inquiry_business_events")
}

model InquiryStateDecision {
  id                       String        @id @default(dbgenerated("'state_decision_' || gen_random_uuid()::TEXT"))
  inquiryCaseId            String        @map("inquiry_case_id")
  emailMessageId           String?       @map("email_message_id")
  analysisDecisionId       String?       @unique @map("analysis_decision_id")
  replayRunId              String?       @map("replay_run_id")
  beforeBusinessStage      InquiryBusinessStage   @map("before_business_stage")
  beforeActionOwner        InquiryActionOwner     @map("before_action_owner")
  beforeLifecycleStatus    InquiryLifecycleStatus @map("before_lifecycle_status")
  beforeStateVersion       Int           @map("before_state_version")
  suggestedBusinessStage   InquiryBusinessStage   @map("suggested_business_stage")
  suggestedActionOwner     InquiryActionOwner     @map("suggested_action_owner")
  suggestedLifecycleStatus InquiryLifecycleStatus @map("suggested_lifecycle_status")
  appliedBusinessStage     InquiryBusinessStage?  @map("applied_business_stage")
  appliedActionOwner       InquiryActionOwner?    @map("applied_action_owner")
  appliedLifecycleStatus   InquiryLifecycleStatus? @map("applied_lifecycle_status")
  confidence               Decimal?      @db.Decimal(5, 4)
  riskLevel                String?       @map("risk_level")
  eventValidationPassed    Boolean       @default(false) @map("event_validation_passed")
  humanReviewAdvisory      Boolean       @default(false) @map("human_review_advisory")
  baselineIncomplete       Boolean       @default(false) @map("baseline_incomplete")
  executionStatus          String        @default("pending") @map("execution_status")
  executionReason          String?       @map("execution_reason")
  policyVersion            String        @map("policy_version")
  decisionSource           String        @default("ai") @map("decision_source")
  eventOccurredAt          DateTime      @map("event_occurred_at") @db.Timestamptz(6)
  executedAt               DateTime?     @map("executed_at") @db.Timestamptz(6)
  createdAt                DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime      @default(now()) @map("updated_at") @db.Timestamptz(6)
  inquiryCase              InquiryCase   @relation(fields: [inquiryCaseId], references: [id], onDelete: Cascade)
  emailMessage             EmailMessage? @relation(fields: [emailMessageId], references: [id], onDelete: SetNull)
  analysisDecision         EmailAnalysisDecision? @relation(fields: [analysisDecisionId], references: [id], onDelete: SetNull)
  transitions             InquiryStateTransition[]

  @@index([inquiryCaseId, eventOccurredAt])
  @@index([executionStatus])
  @@index([replayRunId])
  @@map("inquiry_state_decisions")
}

model InquiryStateTransition {
  id                  String        @id @default(dbgenerated("'state_transition_' || gen_random_uuid()::TEXT"))
  inquiryCaseId       String        @map("inquiry_case_id")
  stateDecisionId     String        @map("state_decision_id")
  fromBusinessStage   InquiryBusinessStage   @map("from_business_stage")
  fromActionOwner     InquiryActionOwner     @map("from_action_owner")
  fromLifecycleStatus InquiryLifecycleStatus @map("from_lifecycle_status")
  toBusinessStage     InquiryBusinessStage   @map("to_business_stage")
  toActionOwner       InquiryActionOwner     @map("to_action_owner")
  toLifecycleStatus   InquiryLifecycleStatus @map("to_lifecycle_status")
  changedDimensionsJson Json        @default("[]") @map("changed_dimensions_json")
  reason              String?
  changedBy           String?       @map("changed_by")
  changedByType       String        @map("changed_by_type")
  eventOccurredAt     DateTime      @map("event_occurred_at") @db.Timestamptz(6)
  processedAt         DateTime      @default(now()) @map("processed_at") @db.Timestamptz(6)
  createdAt           DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  inquiryCase         InquiryCase   @relation(fields: [inquiryCaseId], references: [id], onDelete: Cascade)
  stateDecision       InquiryStateDecision @relation(fields: [stateDecisionId], references: [id], onDelete: Cascade)

  @@index([inquiryCaseId, eventOccurredAt])
  @@index([stateDecisionId])
  @@map("inquiry_state_transitions")
}

model EmailRecoveryRecord {
  id                 String        @id @default(dbgenerated("'recovery_' || gen_random_uuid()::TEXT"))
  inquiryCaseId      String?       @map("inquiry_case_id")
  triggerEmailId     String        @map("trigger_email_id")
  recoveredEmailId   String        @map("recovered_email_id")
  expectedMessageId  String        @map("expected_message_id")
  confidence         Decimal       @db.Decimal(5, 4)
  evidenceJson       Json          @default("{}") @map("evidence_json")
  recoveryStatus     String        @default("context_only") @map("recovery_status")
  replayRunId        String?       @map("replay_run_id")
  baselineIncomplete Boolean       @default(false) @map("baseline_incomplete")
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime      @default(now()) @map("updated_at") @db.Timestamptz(6)
  inquiryCase        InquiryCase?  @relation(fields: [inquiryCaseId], references: [id], onDelete: SetNull)
  triggerEmail       EmailMessage  @relation("RecoveryTriggerEmail", fields: [triggerEmailId], references: [id], onDelete: Cascade)
  recoveredEmail     EmailMessage  @relation("RecoveredEmail", fields: [recoveredEmailId], references: [id], onDelete: Cascade)

  @@unique([triggerEmailId, recoveredEmailId])
  @@index([inquiryCaseId])
  @@index([recoveryStatus])
  @@map("email_recovery_records")
}

model InquiryStructuredFact {
  id                         String        @id @default(dbgenerated("'facts_' || gen_random_uuid()::TEXT"))
  inquiryCaseId              String        @unique @map("inquiry_case_id")
  productType                String?       @map("product_type")
  structureType              String?       @map("structure_type")
  frequencyRange             String?       @map("frequency_range")
  power                      String?
  insertionLoss              String?       @map("insertion_loss")
  isolation                  String?
  vswr                       String?
  connector                  String?
  sizeRequirement            String?       @map("size_requirement")
  quantity                   String?
  application                String?
  deliveryRequirement        String?       @map("delivery_requirement")
  specialRequirements        Json          @default("{}") @map("special_requirements")
  missingFields              Json          @default("[]") @map("missing_fields")
  confirmedFields            Json          @default("[]") @map("confirmed_fields")
  uncertainFields            Json          @default("{}") @map("uncertain_fields")
  sourceEmailMessageIds      Json          @default("[]") @map("source_email_message_ids")
  confidence                 Decimal?      @db.Decimal(5, 4)
  lastUpdatedBy              String        @default("system") @map("last_updated_by")
  updatedFromEmailMessageId  String?       @map("updated_from_email_message_id")
  createdAt                  DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                  DateTime      @default(now()) @map("updated_at") @db.Timestamptz(6)
  inquiryCase                InquiryCase   @relation(fields: [inquiryCaseId], references: [id], onDelete: Cascade)
  updatedFromEmailMessage    EmailMessage? @relation(fields: [updatedFromEmailMessageId], references: [id], onDelete: SetNull)

  @@index([productType])
  @@map("inquiry_structured_facts")
}

model ReplyDraft {
  id                       String        @id @default(dbgenerated("'draft_' || gen_random_uuid()::TEXT"))
  inquiryCaseId            String        @map("inquiry_case_id")
  sourceEmailMessageId     String?       @map("source_email_message_id")
  sentEmailMessageId       String?       @map("sent_email_message_id")
  contextSnapshotId        String?       @map("context_snapshot_id")
  emailAnalysisDecisionId  String?       @map("email_analysis_decision_id")
  idempotencyKey           String?       @unique @map("idempotency_key")
  draftType                String        @map("draft_type")
  status                   String        @default("pending_review")
  subject                  String?
  bodyText                 String        @map("body_text")
  originalSubject          String?       @map("original_subject")
  originalBodyText         String?       @map("original_body_text")
  language                 String?
  usedFactsJson            Json          @default("[]") @map("used_facts_json")
  unresolvedQuestionsJson  Json          @default("[]") @map("unresolved_questions_json")
  warningsJson             Json          @default("[]") @map("warnings_json")
  requiresCommercialReview Boolean       @default(false) @map("requires_commercial_review")
  promptVersion            String?       @map("prompt_version")
  modelName                String?       @map("model_name")
  version                  Int           @default(1)
  createdByType            String        @default("ai") @map("created_by_type")
  approvedBy               String?       @map("approved_by")
  approvedAt               DateTime?     @map("approved_at") @db.Timestamptz(6)
  rejectedBy               String?       @map("rejected_by")
  rejectedAt               DateTime?     @map("rejected_at") @db.Timestamptz(6)
  rejectionReason          String?       @map("rejection_reason")
  sentAt                   DateTime?     @map("sent_at") @db.Timestamptz(6)
  lastSendError            String?       @map("last_send_error")
  createdAt                DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime      @default(now()) @map("updated_at") @db.Timestamptz(6)
  inquiryCase              InquiryCase   @relation(fields: [inquiryCaseId], references: [id], onDelete: Cascade)
  sourceEmailMessage       EmailMessage? @relation("ReplyDraftSourceEmail", fields: [sourceEmailMessageId], references: [id], onDelete: SetNull)
  sentEmailMessage         EmailMessage? @relation("ReplyDraftSentEmail", fields: [sentEmailMessageId], references: [id], onDelete: SetNull)
  emailAnalysisDecision    EmailAnalysisDecision? @relation(fields: [emailAnalysisDecisionId], references: [id], onDelete: SetNull)
  attachments              ReplyDraftAttachment[]
  sendAttempts             EmailSendAttempt[]

  @@index([inquiryCaseId])
  @@index([status])
  @@index([sourceEmailMessageId])
  @@index([sentEmailMessageId])
  @@index([emailAnalysisDecisionId])
  @@map("reply_drafts")
}

model ReplyDraftAttachment {
  replyDraftId      String          @map("reply_draft_id")
  emailAttachmentId String          @map("email_attachment_id")
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  replyDraft        ReplyDraft      @relation(fields: [replyDraftId], references: [id], onDelete: Cascade)
  emailAttachment   EmailAttachment @relation(fields: [emailAttachmentId], references: [id], onDelete: Restrict)

  @@id([replyDraftId, emailAttachmentId])
  @@index([emailAttachmentId])
  @@map("reply_draft_attachments")
}

model EmailSendAttempt {
  id                     String        @id @default(dbgenerated("'send_attempt_' || gen_random_uuid()::TEXT"))
  replyDraftId           String        @map("reply_draft_id")
  inquiryCaseId          String        @map("inquiry_case_id")
  outboundEmailMessageId String?       @map("outbound_email_message_id")
  operationMode          String        @map("operation_mode")
  provider               String
  status                 String
  idempotencyKey         String        @unique @map("idempotency_key")
  messageId              String?       @map("message_id")
  recipient              String
  subject                String
  initiatedBy            String        @map("initiated_by")
  providerResponseJson   Json          @default("{}") @map("provider_response_json")
  errorCode              String?       @map("error_code")
  errorMessage           String?       @map("error_message")
  startedAt              DateTime      @default(now()) @map("started_at") @db.Timestamptz(6)
  completedAt            DateTime?     @map("completed_at") @db.Timestamptz(6)
  createdAt              DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  replyDraft             ReplyDraft    @relation(fields: [replyDraftId], references: [id], onDelete: Restrict)
  inquiryCase            InquiryCase   @relation(fields: [inquiryCaseId], references: [id], onDelete: Restrict)
  outboundEmailMessage   EmailMessage? @relation(fields: [outboundEmailMessageId], references: [id], onDelete: SetNull)

  @@index([replyDraftId])
  @@index([inquiryCaseId])
  @@index([status])
  @@index([startedAt])
  @@map("email_send_attempts")
}

model AiContextSnapshot {
  id               String        @id @default(dbgenerated("'context_snapshot_' || gen_random_uuid()::TEXT"))
  inquiryCaseId    String?       @map("inquiry_case_id")
  emailMessageId   String?       @map("email_message_id")
  purpose          String
  contextPayloadJson Json         @default("{}") @map("context_payload_json")
  messagesJson     Json          @default("[]") @map("messages_json")
  sourceReferences Json          @default("[]") @map("source_references")
  estimatedTokens  Int?          @map("estimated_tokens")
  modelName        String?       @map("model_name")
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  inquiryCase      InquiryCase?  @relation(fields: [inquiryCaseId], references: [id], onDelete: SetNull)
  emailMessage     EmailMessage? @relation(fields: [emailMessageId], references: [id], onDelete: SetNull)

  @@index([inquiryCaseId])
  @@index([emailMessageId])
  @@index([createdAt])
  @@map("ai_context_snapshots")
}

model InquiryContextSummary {
  id                    String      @id @default(dbgenerated("'context_summary_' || gen_random_uuid()::TEXT"))
  inquiryCaseId         String      @unique @map("inquiry_case_id")
  summaryText           String      @map("summary_text")
  knownFactsJson        Json        @default("[]") @map("known_facts_json")
  customerDecisionsJson Json        @default("[]") @map("customer_decisions_json")
  ourCommitmentsJson    Json        @default("[]") @map("our_commitments_json")
  openQuestionsJson     Json        @default("[]") @map("open_questions_json")
  coveredEmailIdsJson   Json        @default("[]") @map("covered_email_ids_json")
  coveredMessageCount   Int         @default(0) @map("covered_message_count")
  coveredFrom           DateTime?   @map("covered_from") @db.Timestamptz(6)
  coveredTo             DateTime?   @map("covered_to") @db.Timestamptz(6)
  createdAt             DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime    @default(now()) @map("updated_at") @db.Timestamptz(6)
  inquiryCase           InquiryCase @relation(fields: [inquiryCaseId], references: [id], onDelete: Cascade)

  @@index([updatedAt])
  @@map("inquiry_context_summaries")
}
